# Stock photo providers for card backgrounds — all optional, all free tiers.
# Copy to .env.local and fill in whichever you sign up for; the first
# configured provider wins. With none set, the keyless Openverse fallback
# is used (lower quality/reliability).

# https://www.pexels.com/api/          (recommended: best quality, exact-crop URLs)
PEXELS_API_KEY=

# https://unsplash.com/developers      (demo tier: 50 requests/hour)
UNSPLASH_ACCESS_KEY=

# https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# --- Instagram auto-publishing (see README "Auto-posting to Instagram") ---
# Credentials are per-channel (src/lib/config.ts). The default (first)
# channel uses the unprefixed vars below. A second channel named e.g.
# "mychannel" would use IG_USER_ID_MYCHANNEL / IG_ACCESS_TOKEN_MYCHANNEL.

# Instagram account's native ID (Instagram API with Instagram Login)
IG_USER_ID=

# Long-lived Instagram Login access token (60 days; refresh before expiry)
IG_ACCESS_TOKEN=

# Public origin of the deployed app — Instagram fetches card images from here.
# e.g. https://intmrkt.vercel.app  (leave empty locally; falls back to request origin)
PUBLIC_BASE_URL=

# Shared secret protecting POST /api/publish (must match the GitHub secret)
CRON_SECRET=
